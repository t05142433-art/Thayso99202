<?xml version="1.0" encoding="utf-8" ?>
<component name="Login" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/Login.brs" />
    <children>
        <!-- Fundo Neon Profundo -->
        <Rectangle width="1920" height="1080" color="0x050505FF" />
        
        <!-- Gradiente de Fundo (Simulado) -->
        <Rectangle width="1920" height="1080" opacity="0.3">
            <Poster width="1920" height="1080" uri="https://picsum.photos/seed/iptv/1920/1080?blur=10" />
        </Rectangle>

        <!-- Container Central com Efeito 3D/Neon -->
        <Group id="loginContainer" translation="[560, 150]">
            <!-- Borda Neon Externa (Glow) -->
            <Rectangle width="810" height="790" translation="[-5, -5]" color="0xFF00FFFF" opacity="0.1" />
            <Rectangle width="800" height="780" color="0xFF00FFFF" opacity="0.2" />
            <Rectangle width="790" height="770" translation="[5, 5]" color="0x101010FF" />
            
            <Label text="Thayson &amp; Thayla IPTV" font="font:LargeBoldSystemFont" color="0x00FFFFFF" translation="[400, 50]" horizAlign="center" />
            <Label text="LOGIN DE ACESSO" font="font:MediumBoldSystemFont" color="0xFF00FFFF" translation="[400, 120]" horizAlign="center" />

            <!-- Campos de Entrada -->
            <Group id="inputsGroup" translation="[100, 200]">
                <!-- Host -->
                <Label text="URL DO SERVIDOR (HOST)" font="font:SmallSystemFont" color="0x888888FF" />
                <Rectangle id="hostBg" width="600" height="70" translation="[0, 30]" color="0x202020FF">
                    <TextEditBox id="hostInput" width="600" height="70" hintText="http://host:porta" textColor="0xFFFFFFFF" hintTextColor="0x555555FF" />
                </Rectangle>

                <!-- Usuário -->
                <Label text="USUÁRIO" font="font:SmallSystemFont" color="0x888888FF" translation="[0, 130]" />
                <Rectangle id="userBg" width="600" height="70" translation="[0, 160]" color="0x202020FF">
                    <TextEditBox id="userInput" width="600" height="70" hintText="Seu usuário" textColor="0xFFFFFFFF" hintTextColor="0x555555FF" />
                </Rectangle>

                <!-- Senha -->
                <Label text="SENHA" font="font:SmallSystemFont" color="0x888888FF" translation="[0, 260]" />
                <Rectangle id="passBg" width="600" height="70" translation="[0, 290]" color="0x202020FF">
                    <TextEditBox id="passInput" width="600" height="70" hintText="Sua senha" secureMode="true" textColor="0xFFFFFFFF" hintTextColor="0x555555FF" />
                </Rectangle>
            </Group>

            <!-- Botões -->
            <Group id="buttonsGroup" translation="[100, 600]">
                <Rectangle id="btnContinueBg" width="280" height="80" color="0x00FFFF33">
                    <Label id="btnContinueText" text="ENTRAR" width="280" height="80" horizAlign="center" vertAlign="center" font="font:MediumBoldSystemFont" color="0x00FFFFFF" />
                </Rectangle>
                
                <Rectangle id="btnCancelBg" width="280" height="80" translation="[320, 0]" color="0x333333FF">
                    <Label id="btnCancelText" text="SAIR" width="280" height="80" horizAlign="center" vertAlign="center" font="font:MediumBoldSystemFont" color="0x888888FF" />
                </Rectangle>
            </Group>
            
            <Label id="errorLabel" color="0xFF0000FF" translation="[400, 720]" horizAlign="center" font="font:SmallSystemFont" />
        </Group>
    </children>
    
    <interface>
        <field id="loginSuccess" type="bool" alwaysNotify="true" />
    </interface>
</component>
