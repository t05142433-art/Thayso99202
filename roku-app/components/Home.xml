<?xml version="1.0" encoding="utf-8" ?>
<component name="Home" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/Home.brs" />
    <children>
        <Rectangle width="1920" height="1080" color="0x050505FF" />
        
        <!-- Background Glow -->
        <Rectangle width="1920" height="1080" opacity="0.1">
            <Poster width="1920" height="1080" uri="https://picsum.photos/seed/iptv_home/1920/1080?blur=15" />
        </Rectangle>

        <!-- Sidebar Neon -->
        <Rectangle id="sideMenu" width="350" height="1080" color="0x0A0A0AFF">
            <Rectangle width="2" height="1080" translation="[348, 0]" color="0xFF00FFFF" opacity="0.3" />
            
            <Group id="logoGroup" translation="[175, 80]">
                <Label text="Thayson &amp; Thayla" font="font:SmallBoldSystemFont" color="0xFF00FFFF" horizAlign="center" />
                <Label text="IPTV PREMIUM" font="font:SmallSystemFont" color="0x888888FF" translation="[0, 30]" horizAlign="center" />
            </Group>
            
            <LabelList id="menuList" width="350" height="800" 
                       itemSize="[350, 110]" 
                       translation="[0, 200]" 
                       color="0x888888FF" 
                       focusedColor="0xFF00FFFF" 
                       focusedFont="font:MediumBoldSystemFont" />
                       
            <!-- User Info Section -->
            <Group id="userInfo" translation="[20, 950]">
                <Rectangle width="310" height="100" color="0x151515FF" />
                <Label id="userLabel" text="USUÁRIO: ---" font="font:SmallSystemFont" color="0xAAAAAAFF" translation="[10, 10]" />
                <Label id="validityLabel" text="VALIDADE: --/--/----" font="font:SmallBoldSystemFont" color="0x00FFFF99" translation="[10, 40]" />
                <Label id="statusLabel" text="STATUS: ATIVO" font="font:SmallSystemFont" color="0x00FF00FF" translation="[10, 70]" />
            </Group>
        </Rectangle>
        
        <!-- Main Content Area -->
        <Group id="contentArea" translation="[400, 50]">
            <Label id="titleLabel" text="CANAIS AO VIVO" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
            
            <!-- Category Filter -->
            <Label id="categoryLabel" text="TODOS OS CANAIS" font="font:SmallBoldSystemFont" color="0x888888FF" translation="[0, 80]" />
            
            <!-- Content Grid with 3D Effect -->
            <PosterGrid id="contentGrid" 
                        translation="[0, 150]" 
                        itemSize="[240, 360]" 
                        baseGridSize="[1450, 850]" 
                        numColumns="5" 
                        numRows="2" 
                        itemSpacing="[40, 40]" 
                        focusBitmapUri="pkg:/images/focus_neon.png" />
        </Group>
        
        <!-- Video Player Overlay -->
        <VideoPlayer id="videoPlayer" visible="false" />
    </children>
</component>
